<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Invoice #<%= invoice.invoiceNumber %></title>
  <style>
    body { font-family: Arial, sans-serif; color: #333; margin: 0; padding: 20px; }
    .header { background: linear-gradient(135deg, #1a1a2e, #16213e); color: #fff; padding: 30px; border-radius: 8px 8px 0 0; }
    .header h1 { margin: 0; font-size: 26px; }
    .header p { color: #c9a84c; margin: 5px 0 0; }
    .body { border: 1px solid #eee; border-top: none; padding: 30px; }
    table { width: 100%; border-collapse: collapse; margin: 20px 0; }
    th { background: #f0f4ff; padding: 12px; text-align: left; border-bottom: 2px solid #c9a84c; }
    td { padding: 10px 12px; border-bottom: 1px solid #eee; }
    .total { font-size: 18px; font-weight: bold; color: #1a1a2e; }
    .footer { text-align: center; font-size: 12px; color: #999; margin-top: 20px; }
  </style>
</head>
<body>
  <div class="header">
    <h1>🏨 Hotel & Resort</h1>
    <p>INVOICE</p>
  </div>
  <div class="body">
    <table>
      <tr><td><strong>Invoice #</strong></td><td><%= invoice.invoiceNumber %></td></tr>
      <tr><td><strong>Date</strong></td><td><%= new Date(invoice.createdAt).toLocaleDateString() %></td></tr>
      <tr><td><strong>Customer</strong></td><td><%= customer.firstName %> <%= customer.lastName %></td></tr>
      <tr><td><strong>Email</strong></td><td><%= customer.email %></td></tr>
    </table>
    <table>
      <thead><tr><th>Description</th><th>Qty</th><th>Unit Price</th><th>Total</th></tr></thead>
      <tbody>
        <% invoice.items.forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td><%= item.quantity %></td>
          <td>BDT <%= item.unitPrice.toLocaleString() %></td>
          <td>BDT <%= item.totalPrice.toLocaleString() %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <table>
      <tr><td>Subtotal</td><td>BDT <%= invoice.subtotal.toLocaleString() %></td></tr>
      <tr><td>Tax (<%= invoice.taxRate %>%)</td><td>BDT <%= invoice.taxAmount.toLocaleString() %></td></tr>
      <tr class="total"><td><strong>Total</strong></td><td><strong>BDT <%= invoice.totalAmount.toLocaleString() %></strong></td></tr>
    </table>
  </div>
  <div class="footer">© <%= new Date().getFullYear() %> Hotel & Resort Management System. Thank you for your business!</div>
</body>
</html>
